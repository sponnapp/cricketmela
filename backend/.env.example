# Backend Environment Variables (.env)
# Copy this file to .env and update values as needed

# Server Port
PORT=4000

# Node Environment (development, production)
NODE_ENV=development

# Database Path (leave empty for default, or specify custom path)
# In production (Fly.io), this will be /app/data
# DB_PATH=

# CORS Origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:5173,https://cricketmela.pages.dev

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session Secret (change this to a random string in production)
SESSION_SECRET=cricket-mela-super-secret-session-key-change-in-production

# VM / Custom host overrides (leave blank for localhost defaults)
# Set these when running on a remote VM or custom host
# BACKEND_URL=http://161.153.115.59:4000
# FRONTEND_URL=http://161.153.115.59:5173
