# Cloudflare Pages Cache Headers

# Never cache the main HTML entry point — ensures users always get latest app
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Never cache version.json — used for auto-update detection
/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# PWA manifest — never cache, serve with correct content type
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/manifest+json

# PWA icons — short cache so updates propagate quickly
/pwa-192x192.png
  Cache-Control: public, max-age=86400
/pwa-512x512.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# Cache hashed JS/CSS assets forever (Vite adds content hashes to filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache service worker
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

